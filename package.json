{
  "name": "@troisi/ui",
  "version": "0.1.0",
  "description": "Troisi UI \u2014 React components with a from-scratch CSS design system",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cincinnatus101010/TroisiUI.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/troisi-ui.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "css",
    "ui"
  ]
}
